DB_USER=llmproxy
DB_PASSWORD=
DB_NAME=llmproxy

LITELLM_HOST=
LITELLM_MASTER_KEY=
LITELLM_SALT_KEY=

CLI_PROXY_API_HOST=

# Default Traefik router mode for the application stack.
# Keep `web`/`false` when Cloudflare Tunnel sends traffic to http://traefik:80.
TRAEFIK_ROUTER_ENTRYPOINTS=web
TRAEFIK_ROUTER_TLS=false
LETSENCRYPT_RESOLVER=le
