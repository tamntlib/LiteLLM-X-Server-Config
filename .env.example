DB_USER=llmproxy
DB_PASSWORD=
DB_NAME=llmproxy

LITELLM_HOST=
LITELLM_MASTER_KEY=
LITELLM_SALT_KEY=

CLI_PROXY_API_HOST=

# Default Traefik router mode for the application stack.
# Uses HTTPS with Let's Encrypt via Cloudflare DNS challenge.
TRAEFIK_ROUTER_ENTRYPOINTS=websecure
TRAEFIK_ROUTER_TLS=true
LETSENCRYPT_RESOLVER=le
