{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://example.com/litellm-config.schema.json",
    "title": "LiteLLM Config Schema",
    "description": "Configuration schema for LiteLLM proxy management script",
    "type": "object",
    "properties": {
        "$schema": {
            "type": "string",
            "description": "JSON Schema reference"
        },
        "providers": {
            "type": "object",
            "description": "Service providers configuration",
            "additionalProperties": {
                "$ref": "#/$defs/provider"
            }
        },
        "aliases": {
            "type": "object",
            "description": "Model name aliases mapping (alias -> target model)",
            "additionalProperties": {
                "type": "string",
                "description": "Target model name or another alias"
            }
        },
        "fallbacks": {
            "type": "array",
            "description": "Fallback rules for automatic routing on failure",
            "items": {
                "type": "object",
                "description": "Fallback rule mapping source model to fallback targets",
                "additionalProperties": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "description": "Fallback model name, or '$base' to expand base config fallbacks for this key"
                    },
                    "description": "List of fallback model names. Use '$base' to reference base config fallbacks."
                }
            }
        },
        "public_model_hub": {
            "type": "array",
            "description": "List of model group names or aliases to expose in LiteLLM public model hub",
            "items": {
                "type": "string"
            }
        },
        "public_model_hub_autofill_disabled": {
            "type": "boolean",
            "description": "Disable autofilling public_model_hub from derived model defaults"
        },
        "public_model_hub_aliases_autofill_disabled": {
            "type": "boolean",
            "description": "Disable autofilling public_model_hub from aliases"
        },
        "model_name_base_model_map": {
            "type": "object",
            "description": "Global mapping of model names to base_model identifiers. Used as fallback when a model does not specify its own base_model.",
            "additionalProperties": {
                "type": "string",
                "description": "Base model identifier (e.g. 'anthropic/claude-opus-4-6')"
            }
        }
    },
    "$defs": {
        "provider": {
            "type": "object",
            "description": "Provider configuration",
            "properties": {
                "$extend": {
                    "type": ["string", "null"],
                    "description": "Inherit configuration from another provider. Set to null to remove inheritance."
                },
                "api_key": {
                    "type": "string",
                    "description": "API key for authentication (typically in config.local.json)"
                },
                "api_base": {
                    "type": "string",
                    "description": "Base URL for the API endpoint"
                },
                "models_api_base": {
                    "type": "string",
                    "description": "Base URL for the /models listing endpoint (defaults to api_base if not specified)"
                },
                "access_groups": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "description": "Access groups for model visibility"
                },
                "is_public_model_hub": {
                    "type": "boolean",
                    "description": "Default public model hub visibility for all models under this provider"
                },
                "interfaces": {
                    "type": "object",
                    "description": "Provider interfaces (openai, gemini, anthropic)",
                    "properties": {
                        "openai": {
                            "$ref": "#/$defs/interface"
                        },
                        "gemini": {
                            "$ref": "#/$defs/interface"
                        },
                        "anthropic": {
                            "$ref": "#/$defs/interface"
                        }
                    },
                    "additionalProperties": false
                }
            },
            "additionalProperties": false
        },
        "interface": {
            "type": "object",
            "description": "Interface-specific configuration",
            "properties": {
                "models_autofill_disabled": {
                    "type": "boolean",
                    "description": "Set to true to disable auto-fetching models from the provider's API. Autofill is enabled by default."
                },
                "model_name_prefix": {
                    "type": "string",
                    "description": "Prefix for derived model group names on this interface. Defaults to the interface name when omitted."
                },
                "models": {
                    "type": "object",
                    "description": "Models available through this interface",
                    "additionalProperties": {
                        "$ref": "#/$defs/model"
                    }
                }
            },
            "additionalProperties": false
        },
        "model": {
            "oneOf": [
                {
                    "type": "object",
                    "description": "Model configuration",
                    "properties": {
                        "ignored": {
                            "type": "boolean",
                            "description": "If true, skip exposing this model completely."
                        },
                        "model_name": {
                            "type": "string",
                            "description": "Model group name (defaults to the key if not specified)"
                        },
                        "access_groups": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            },
                            "description": "Access groups for this model (overrides provider-level access_groups)"
                        },
                        "is_public_model_hub": {
                            "type": "boolean",
                            "description": "Whether this model should be exposed in LiteLLM's public model hub (overrides provider-level default)"
                        },
                        "model_info": {
                            "type": "object",
                            "description": "Model metadata",
                            "properties": {
                                "base_model": {
                                    "type": "string",
                                    "description": "Base model identifier for pricing/capabilities lookup"
                                }
                            },
                            "additionalProperties": true
                        },
                        "litellm_params": {
                            "type": "object",
                            "description": "Additional LiteLLM parameters",
                            "additionalProperties": true
                        }
                    },
                    "additionalProperties": false
                },
                {
                    "type": "null",
                    "description": "Empty model config (use defaults)"
                }
            ]
        }
    },
    "additionalProperties": false
}
