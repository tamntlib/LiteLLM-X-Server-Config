# Monitoring Stack Environment Variables
# Copy this to .env and fill in the values

# Netdata hostname for Traefik routing
NETDATA_HOST=netdata.example.com

# Default Traefik router mode for the monitoring stack.
# Keep `web`/`false` when Cloudflare Tunnel sends traffic to http://traefik:80.
TRAEFIK_ROUTER_ENTRYPOINTS=web
TRAEFIK_ROUTER_TLS=false
LETSENCRYPT_RESOLVER=le

# Basic auth for Netdata dashboard (REQUIRED)
# Generate with: htpasswd -nb admin <yourpassword>
# Example output: admin:$$apr1$$xyz...
NETDATA_BASIC_AUTH=
