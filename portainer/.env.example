PORTAINER_HOST=portainer.example.com

# Default Traefik router mode for Portainer and the application stacks.
# Keep `web`/`false` when using Cloudflare Tunnel to reach Traefik on port 80.
TRAEFIK_ROUTER_ENTRYPOINTS=web
TRAEFIK_ROUTER_TLS=false
LETSENCRYPT_RESOLVER=le

# Optional Cloudflare Tunnel connector. Set replicas to 1 after creating
# a remotely managed tunnel in Cloudflare Zero Trust.
CLOUDFLARE_TUNNEL_REPLICAS=0
CLOUDFLARE_TUNNEL_TOKEN=

# Required only when deploying portainer/portainer.letsencrypt.yaml.
LETSENCRYPT_EMAIL=
