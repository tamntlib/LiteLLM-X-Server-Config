PORTAINER_HOST=portainer.example.com

# Cloudflare API token for Let's Encrypt DNS challenge.
# Create at https://dash.cloudflare.com/profile/api-tokens with Zone:DNS:Edit permission.
CF_DNS_API_TOKEN=

LETSENCRYPT_EMAIL=

# Default Traefik router mode. Uses HTTPS with Let's Encrypt.
TRAEFIK_ROUTER_ENTRYPOINTS=websecure
TRAEFIK_ROUTER_TLS=true
LETSENCRYPT_RESOLVER=le
